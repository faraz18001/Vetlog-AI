{
  "manifest_version": 3,
  "name": "Vetlog WhatsApp Scraper",
  "version": "1.0",
  "description": "Scrapes WhatsApp Web messages for Vetlog integration.",
  "permissions": [
    "storage", 
    "unlimitedStorage", 
    "activeTab", 
    "scripting"
  ],
  "host_permissions": [
    "https://web.whatsapp.com/*"
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["https://web.whatsapp.com/*"],
      "js": ["content_script.js"]
    }
  ]
}